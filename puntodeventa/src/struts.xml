		<!--Ver tiket de venta en pdf , enviar por correo,watss,imprimir y descargar-->
		<!-- este action visuliza el tiket en navegador web,pero toma el adobe acrobat -->

		<!-- =============================== -->
		<!-- VER VISOR -->
		<!-- =============================== -->
		<action name="verTicketVenta" class="servicepv.VerTicketVentaAction">
			<result name="success">/Ventas/VerTicketVenta.jsp</result>
		</action>

		<!-- =============================== -->
		<!-- STREAM PDF -->
		<!-- =============================== -->
		<action name="descargarTicketPdf" class="servicepv.DescargarTicketPdfAction">

			<result name="success" type="stream">
				<param name="contentType">application/pdf</param>
				<param name="inputName">inputStream</param>
				<param name="contentDisposition">
					inline;filename="${fileName}"
				</param>
				<param name="bufferSize">1024</param>
			</result>

			<result name="error">/acceso/MensajeX.html</result>
		</action>

		<!-- =============================== -->
		<!-- ENVIA POR CORREO EL TICKET -->
		<!-- =============================== -->
		<action name="enviarCorreoTicket"
