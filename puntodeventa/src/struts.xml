  <package name="authentication" namespace="/"
		extends="struts-default">
		<interceptors>
			<interceptor name="authenticationInterceptor"
				class="Auth.interceptor.AuthenticationInterceptor" />
			<interceptor-stack name="secureStack">
				<interceptor-ref name="authenticationInterceptor"></interceptor-ref>
				<interceptor-ref name="defaultStack"></interceptor-ref>
			</interceptor-stack>
		</interceptors>

		<!-- HOME ACTION PUBLICO -->

		<action name="homeaction"  class="Acceso.Control.HomeAction">
		<interceptor-ref name="defaultStack"/>
			<result name="success">/acceso/login.jsp</result>
		</action> 

		<!-- LOGIN SEGURO -->
		<action name="login" class="Acceso.Control.LoginAction">
			<interceptor-ref name="secureStack" />
			<result name="success">/acceso/Home.jsp</result>
			<result name="inicio">/general/Error.jsp</result>
			<result name="homeaction" type="redirectAction">
				<param name="actionName">homeaction</param>
				<param name="namespace">/</param>
			</result>			
		</action> 

